# Copy this file to .env and fill in your values
# Do not commit .env to version control
#
# Council district lookup uses bundled GeoJSON + data/council-members.json (no API key).

# EmailJS (for sending advocacy emails)
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
# Optional: admin notification template - you get an email each time someone sends
EMAILJS_ADMIN_TEMPLATE_ID=
# Optional: BCC yourself a copy of every advocacy email (your@email.com)
EMAILJS_BCC_EMAIL=

# Supabase (for admin panel / send logging)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# ADMIN_SECRET: set via "supabase secrets set ADMIN_SECRET=..." — not in .env
